# ============================================================
# Supabase
# ============================================================
# Supabase Dashboard > Settings > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase Dashboard > Settings > API > anon public key
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Dashboard > Settings > API > service_role key（サーバーサイド専用・RLSバイパス）
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ============================================================
# LINE Messaging API
# ============================================================
# LINE Developers Console > チャネル基本設定 > チャンネルシークレット
LINE_CHANNEL_SECRET=your-line-channel-secret

# LINE Developers Console > Messaging API設定 > チャンネルアクセストークン
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token

# ============================================================
# LIFF（LINE Front-end Framework / フロントエンド公開変数）
# ============================================================
# ⚠️ LIFFは「LINEログインチャネル」が必要です（Messaging APIチャネルでは作成不可）
#
# 取得手順:
# 1. LINE Developers Console > 同じプロバイダー内に「LINEログイン」チャネルを新規作成
# 2. LINEログインチャネル > LIFF タブ > 「追加」
# 3. サイズ: Full / エンドポイントURL: https://your-domain.com/reserve
# 4. Scope: profile / ボットリンク機能: On (Aggressive)
# 5. 作成後のLIFF IDをここに貼り付け
#
# 形式例: 2009330357-AnI0gz2I
NEXT_PUBLIC_LIFF_ID=your-liff-id

# ============================================================
# Cron認証（前日リマインド通知用）
# ============================================================
# 任意のランダム文字列（例: openssl rand -hex 32 で生成）
CRON_SECRET=your-cron-secret
